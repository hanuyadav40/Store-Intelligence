FROM python:3.12.2-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Dashboard only needs a lightweight HTTP server + templating
RUN pip install --no-cache-dir fastapi==0.115.5 uvicorn[standard]==0.32.1 httpx==0.28.1 aiofiles==24.1.0 jinja2==3.1.4

COPY dashboard/ ./dashboard/

EXPOSE 3000

CMD ["uvicorn", "dashboard.main:app", "--host", "0.0.0.0", "--port", "3000"]
