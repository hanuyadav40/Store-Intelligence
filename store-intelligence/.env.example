# Application
APP_NAME=Store Intelligence API
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Detection
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.4
IOU_THRESHOLD=0.5

# Tracking
TRACK_ACTIVATION_THRESHOLD=0.25
LOST_TRACK_BUFFER=30
MINIMUM_MATCHING_THRESHOLD=0.8
FRAME_RATE=25

# Business Logic
SESSION_WINDOW_MINUTES=30
STAFF_DWELL_THRESHOLD_HOURS=4.0
GROUP_ENTRY_WINDOW_SECONDS=2.0
GROUP_ENTRY_MIN_SIZE=2

# Virtual line (fraction of frame height from top)
ENTRY_LINE_Y_FRACTION=0.4

# Camera
CAMERA_ID=cam_01

# Data
DATA_DIR=/app/data
SALES_CSV_PATH=/app/data/sales.csv

# Prometheus
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=8001

# Anomaly thresholds
FOOTFALL_SPIKE_THRESHOLD=2.0
DWELL_TIME_ANOMALY_MINUTES=60.0
CROWD_THRESHOLD=10

# Demo mode (true = generate synthetic data when no video found)
DEMO_MODE=true
DEMO_INTERVAL_SECONDS=5
