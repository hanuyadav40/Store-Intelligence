# Environment configuration — copy to .env and fill values
DATABASE_URL=postgresql+asyncpg://si_user:si_password@localhost:5432/store_intelligence
SYNC_DATABASE_URL=postgresql+psycopg2://si_user:si_password@localhost:5432/store_intelligence
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-a-long-random-string
STORE_LAYOUT_PATH=./data/store_layout.json
POS_DATA_PATH=./data/pos_transactions.csv
ENVIRONMENT=development

# Pipeline settings
API_URL=http://localhost:8000
DETECTION_CONFIDENCE=0.35
REID_SIMILARITY_THRESHOLD=0.72
REENTRY_WINDOW_SECONDS=300
STAFF_TRACK_RATIO=0.80
